{
  "name": "xr-root",
  "private": true,
  "version": "1.0.0",
  "description": "XR Vision root runner",
  "scripts": {
    "start": "npm-run-all --parallel start:hub start:web",
    "start:hub": "npm --prefix desktop-web/backend start",
    "start:web": "npm --prefix device-pwa/backend start",

    "dev": "npm-run-all --parallel dev:hub dev:web",
    "dev:hub": "npm --prefix desktop-web/backend run dev",
    "dev:web": "npm --prefix device-pwa/backend run dev",

    "bootstrap": "npm --prefix desktop-web/backend install && npm --prefix device-pwa/backend install"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  },
  "author": "Your Name",
  "license": "MIT"
}
